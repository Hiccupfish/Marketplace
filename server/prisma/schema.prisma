generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Seller {
  id          Int      @id @default(autoincrement())
  name        String
  email       String   @unique
  password    String
  phone       String?
  city        String?
  bio         String?
  category    String?
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  verified    Boolean  @default(false)
  avatarUrl   String?
  listings    Listing[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Listing {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  priceZar    Float
  category    String
  city        String
  sellerId    Int
  seller      Seller   @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
